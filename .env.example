# Nukopijuok VISĄ šį bloką į naują failą .env toje pačioje šaknyje (šalia package.json).
# Tada vietoje tuščių eilučių įrašyk slaptažodžius ir raktus (be kabučių).

# --- Microsoft Graph (rekomenduojama su Security defaults ON) ---
# Entra: nauja programėlė → Certificates & secrets → client secret.
# API permissions → Microsoft Graph → Application permissions:
#   Mail.Read, Mail.Send → Grant admin consent for <tenant>.
# Užpildžius šias keturias eilutes, aplikacija naudoja Graph vietoj IMAP/SMTP (slaptažodžių „basic auth“ nereikia).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_MAILBOX_USER=

# --- El. pašto skaitymas (IMAP) — tik jei Graph neįjungtas ---
# IV / kitas tiekėjas: pakeisk IMAP_HOST pagal jų instrukciją.
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
# Tas pats vartotojas kaip SMTP (pvz. Tomo prisijungimas prie M365)
IMAP_USER=
IMAP_PASSWORD=

# Importo taisyklės (kaip n8n — tik leidžiami gamintojai):
# - ALLOWED_SENDERS arba DB AllowedSender: tik šių From kuriami užsakymai
# - MAIL_SUBJECT_FILTER: tuščia = be papildomo temos filtro. Jei nurodyta — temoje turi būti ši eilutė.
ALLOWED_SENDERS=gamintojas1@example.com,gamintojas2@example.com
MAIL_SUBJECT_FILTER=

# Po sėkmingo importo pažymėti laišką kaip perskaitytą (true/false)
MAIL_MARK_SEEN=false

# Vidiniai POST /api/internal/* ir (pasirinktinai) cron: Bearer token
SYNC_SECRET=
# Vercel Cron siunčia Authorization: Bearer <CRON_SECRET>. Dažnai = tas pats kaip SYNC_SECRET.
CRON_SECRET=

# Vežėjų atsakymų analizei ir gamintojų laiškų struktūrizavimui (be rakto — „šalis“ tik iš temos, likę laukai prasti)
GOOGLE_GENERATIVE_AI_API_KEY=
# Pasirinktinai: Gemini modelis (numatytasis gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Jei klaida „self-signed certificate in certificate chain“ (antivirusas, įmonės SSL proxy) — true tik vystymui
MAIL_TLS_INSECURE=false

# --- Siuntimas (SMTP) — Microsoft 365 ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Vežėjų laiškas: To (numatytai orders@digroup.lt) + BCC pagal šalį (IT/PL/NL kaip n8n)
CARRIER_ORDERS_TO_EMAIL=orders@digroup.lt

# --- Postgres (įprastas prisijungimas) ---
# Formatas: postgresql://USER:PASS@HOST:5432/DB arba postgres://...
# Jei klaida „URL must start with prisma:// or prisma+postgres://“: ne naudokite
# prisma generate --no-engine, o paleiskite „npx prisma generate“; Next dev paleiskite iš naujo.
# Nejunkite PRISMA_ACCELERATE_URL, jei nenaudojate Accelerate.
DATABASE_URL=
