
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_MAILBOX_USER=
CRON_SECRET=
# Rankiniam sync (POST /api/internal/sync-mail ir sync-offers)
SYNC_SECRET=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Pasiūlymų lyginimui: PVM tarifas (0.21 = 21%), kai kaina nurodyta su PVM
VAT_RATE=0.21
CARRIER_ORDERS_TO_EMAIL=orders@digroup.lt
# Supabase (arba Neon): runtime — pooler / transaction (Vercel serverless).
# Supabase Dashboard → Connect → ORM: Prisma — nukopijuok abu URL.
# Pvz. postgres.[REF]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# Migracijos / prisma db push — „Direct“ iš to paties Connect (dažnai tas pats hostas, portas 5432).
# Vercel build (postinstall: prisma generate) reikalauja, kad kintamasis būtų nustatytas (gali būti tas pats kaip lokaliai).
DIRECT_URL=
# Tikslūs el. paštai (kableliais) arba DB AllowedSender. Būtina produkcijoje.
# Gamintojų From (bolia.com, sabaitalia, dorota_owl@mail.ru ir pan.) — automatiškai iš manufacturer-inbound-rules.json.
# SVARBU: temos raktas (pvz. „Bolia“ temoje) NĖRA whitelist — tik From adresas.
ALLOWED_SENDERS=
# Tik lokaliai / testui: true = jei whitelist tuščias, leisti visus siuntėjus (produkcijoje NENAUDOTI).
MAIL_ALLOW_ALL_WHEN_WHITELIST_EMPTY=
# Po whitelist: Gemini nusprendžia, ar laiškas apie krovinio paėmimą (ne vidinis statusų laiškas).
# MAIL_PICKUP_AI_DISABLED=true — išjungia šį žingsnį (senas elgesys).
# MAIL_PICKUP_AI_STRICT=true be API rakto — neimportuoti. MAIL_PICKUP_AI_FAIL_OPEN — DI klaida → vis tiek importuoti.
MAIL_PICKUP_AI_DISABLED=
MAIL_PICKUP_AI_STRICT=
MAIL_PICKUP_AI_FAIL_OPEN=

# Graph sincho režimas:
# - unread (default): neperskaityti + papildomai perskaityti su priedais (žr. žemiau)
# - recent: paskutiniai 50 (read+unread), naujausi pirmi (debug)
MAIL_GRAPH_SYNC_MODE=
# Perskaitytų laiškų su priedais papildomas rinkinys (Furninova loading list PDF ir pan.)
MAIL_GRAPH_ATTACH_LOOKBACK_HOURS=
MAIL_GRAPH_ATTACH_READ_TOP=
MAIL_GRAPH_READ_LOOKBACK_HOURS=
MAIL_GRAPH_SKIP_READ_PASS=
# Neperžiūrėtų limitas ir lookback (default 200 / 336 val.)
MAIL_GRAPH_LIST_TOP=
MAIL_GRAPH_UNREAD_LOOKBACK_HOURS=
# Vežėjų atsakymų importas: kiek naujausių inbox laiškų per cron (default 100)
MAIL_GRAPH_OFFERS_TOP=
