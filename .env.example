# Neon + Vercel: naudokite „pooler“ hostą iš Neon konsolės ir sslmode=require, pvz.
# postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Prisma + PgBouncer: kartais reikia ?pgbouncer=true&connect_timeout=15 — žr. Neon + Prisma docs.
DATABASE_URL=
# Gamintojų From el. paštai (kableliais) arba įrašai DB lentelėje AllowedSender.
# Jei abu tušti — importas nieko nepriima (nebent MAIL_ALLOW_ALL_WHEN_WHITELIST_EMPTY=true).
ALLOWED_SENDERS=
# Tik lokaliai / testui: true = jei whitelist tuščias, leisti visus siuntėjus (produkcijoje nenaudoti).
MAIL_ALLOW_ALL_WHEN_WHITELIST_EMPTY=
