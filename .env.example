
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GRAPH_MAILBOX_USER=
CRON_SECRET=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CARRIER_ORDERS_TO_EMAIL=orders@digroup.lt
# Supabase (arba Neon): runtime — pooler / transaction (Vercel serverless).
# Supabase Dashboard → Connect → ORM: Prisma — nukopijuok abu URL.
# Pvz. postgres.[REF]:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=
# Migracijos / prisma db push — „Direct“ iš to paties Connect (dažnai tas pats hostas, portas 5432).
# Vercel build (postinstall: prisma generate) reikalauja, kad kintamasis būtų nustatytas (gali būti tas pats kaip lokaliai).
DIRECT_URL=
# Papildomi gamintojų From el. paštai (tikslūs, kableliais) arba DB AllowedSender — viršuje n8n taisyklės
# iš src/data/manufacturer-inbound-rules.json (sinchronizuokite su n8n Gamintojai workflow).
ALLOWED_SENDERS=
# Šių domenų siuntėjams neleidžiama importuoti tik pagal temos raktą — turi sutapti From su gamintojo taisykle (numatytai distyle.lt).
MAIL_IMPORT_BLOCK_FROM_DOMAINS=
# Tik lokaliai / testui: true = jei whitelist tuščias, leisti visus siuntėjus (produkcijoje nenaudoti).
MAIL_ALLOW_ALL_WHEN_WHITELIST_EMPTY=
# Po whitelist: Gemini nusprendžia, ar laiškas apie krovinio paėmimą (ne vidinis statusų laiškas).
# MAIL_PICKUP_AI_DISABLED=true — išjungia šį žingsnį (senas elgesys).
# MAIL_PICKUP_AI_STRICT=true be API rakto — neimportuoti. MAIL_PICKUP_AI_FAIL_OPEN — DI klaida → vis tiek importuoti.
MAIL_PICKUP_AI_DISABLED=
MAIL_PICKUP_AI_STRICT=
MAIL_PICKUP_AI_FAIL_OPEN=

# Graph sincho režimas:
# - unread (default): skaito tik neperskaitytus (isRead=false)
# - recent: skaito paskutinius 50 (read+unread), naujausi pirmi (patogu debug, kai laiškas jau „read“)
MAIL_GRAPH_SYNC_MODE=
