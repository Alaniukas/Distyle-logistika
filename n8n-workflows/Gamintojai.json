    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst text = items.map(row => JSON.stringify(row.json)).join('\\n');\n\n// Paimame gamintojo info iš pirmo elemento ir pridedame Excelio tekstą\nreturn { \n  ...items[0].json, \n  text \n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
