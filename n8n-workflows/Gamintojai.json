    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst result = [];\n\nfor (const item of allItems) {\n  const binaryData = item.binary;\n  const messageId = item.json.id;\n\n  if (binaryData) {\n    for (const key of Object.keys(binaryData)) {\n      result.push({\n        json: {\n          ...item.json, // ŠITA EILUTĖ IŠSAUGO GAMINTOJO INFO\n          fileName: binaryData[key].fileName,\n          originalMessageId: messageId\n        },\n        binary: {\n          data: binaryData[key]\n        }\n      });\n    }\n  }\n}\n\nreturn result;"
      },
