      ],
      "id": "ddf0ffc8-de4d-4304-82a5-612bea750ad8",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst result = [];\n\n// Praplečiame taisykles, įtraukdami el. pašto raktus\nconst rules = [\n  { key: 'bolia', email: 'bolia.com', name: 'Bolia' },\n  { key: 'saba', email: 'sabaitalia.com', name: 'Saba Italia' },\n  { key: 'eriks', email: 'eriksfeldmanis', name: 'Saba Italia' },\n  { key: 'furninova', email: 'dorota_owl@mail.ru', name: 'Furninova' }\n];\n\nfor (const item of items) {\n  const emailData = item.json.body;\n  \n  if (emailData) {\n    // Naudojame Apps Script siunčiamus laukus: \"tema\" ir \"siuntejas\"\n    const subject = (emailData.tema || \"\").toLowerCase();\n    const from = (emailData.siuntejas || \"\").toLowerCase();\n    \n    // Ieškome gamintojo pagal TEMĄ arba pagal SIUNTĖJO ADRESĄ\n    const manufacturer = rules.find(r => \n      subject.includes(r.key) || from.includes(r.email)\n    );\n    \n    if (manufacturer) {\n      // Tikriname, ar laiškas yra apie paruoštą užsakymą\n      const isReady = subject.includes('ready') || \n                      subject.includes('atsiemimas') || \n                      subject.includes('patvirtinimas') ||\n                      subject.includes('paruosta'); // Pridėjau \"paruosta\" dėl saugumo\n\n      if (isReady) {\n        result.push({\n          json: {\n            ...emailData,\n            Manufacturer: manufacturer.name\n          }\n        });\n      }\n    }\n  }\n}\n\nreturn result;"
      },
