    {
      "parameters": {
        "jsCode": "// 1. Paimame visus elementus (kad žinotume indeksus)\nconst items = $input.all();\n\nreturn items.map((item, index) => {\n  \n  // --- GEMINI DUOMENYS (Tai veikia gerai) ---\n  const visionData = $('Analyze an image').all()[index].json;\n  let rawText = \"{}\";\n  if (visionData.content?.parts?.[0]?.text) {\n       rawText = visionData.content.parts[0].text;\n  }\n  let geminiData = {};\n  try {\n    geminiData = JSON.parse(rawText.replace(/```json|```/g, \"\").trim());\n  } catch (e) { geminiData = {}; }\n\n\n  // --- SVARBUS PATAISYMAS ČIA ---\n  // Mes neimame duomenų iš 'item' (kuris atėjo iš HTTP Request ir yra tuščias).\n  // Mes žiūrime atgal į 'Loop Over Items' mazgą, kuris vis dar saugo originalią info.\n  \n  const originalData = $('Loop Over Items').all()[index].json;\n  \n  const brandName = originalData.brand_name || \"Nežinomas\"; \n  const imageId = originalData.id; \n  // -----------------------------\n\n\n  // --- VEKTORIAI ---\n  let vector = [];\n  try {\n      // Čia imame iš HTTP Request (tai vienintelis dalykas, ką jis grąžina)\n      vector = $('HTTP Request').all()[index].json.embedding.values;\n  } catch(e) { vector = []; }\n\n  // Grąžiname rezultatą\n  return {\n    json: {\n      brand: brandName,\n      image_id: imageId,\n      embedding: vector,\n      forma: geminiData.forma || \"Nenustatyta\",\n      kojeles: geminiData.kojeles || \"Nenustatyta\",\n      gylis: geminiData.gylis_tonas || geminiData.gylis || \"Nenustatyta\",\n      pagalves: geminiData.pagalves || \"Nenustatyta\",\n      description: geminiData.aprasymas || \"Nėra aprašymo\"\n    }\n  };\n});"
      },
